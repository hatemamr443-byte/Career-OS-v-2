# ────────────────────────────────────────────────────────────
# Career OS — Backend env example
# Copy to .env and fill in your values. Never commit real .env.
# ────────────────────────────────────────────────────────────

# ── Database (required) ─────────────────────────────────────
MONGO_URL="mongodb://localhost:27017"
DB_NAME="career_os"

# ── CORS (required) ─────────────────────────────────────────
# Comma-separated. Use the exact origin of your frontend in prod.
CORS_ORIGINS="*"

# ── AI Provider (one of these is required) ──────────────────
# Option A — Emergent Universal LLM key (recommended for fastest setup)
# Routes Claude Sonnet, Gemini Flash, and GPT through a single key.
EMERGENT_LLM_KEY=

# Option B — Direct provider keys (engaged automatically by llm_service
#  fallback chain when set; can also be primary if Emergent is omitted).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Operations ──────────────────────────────────────────────
# Free-form label used by Sentry + logs
ENVIRONMENT=development

# Secret token used to authenticate the daily welcome-email cron
CRON_TOKEN=change-me

# Optional: Sentry error monitoring
SENTRY_DSN=

# ── Payments (optional) ─────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email (optional) ────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Career OS <noreply@career-os.io>

# ── External job sources (optional, all have free tiers) ────
ADZUNA_APP_ID=
ADZUNA_API_KEY=
JOOBLE_API_KEY=
# Remotive needs no key.
