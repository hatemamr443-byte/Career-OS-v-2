# ────────────────────────────────────────────────────────────
# Career OS — Frontend env example
# Copy to .env and fill in your values. Never commit real .env.
# ────────────────────────────────────────────────────────────

# Base URL of the backend API (must include scheme, no trailing slash).
# All frontend code uses process.env.REACT_APP_BACKEND_URL + "/api/..."
REACT_APP_BACKEND_URL=http://localhost:8001

# Optional: hot-reload websocket port (only needed in some hosted envs).
WDS_SOCKET_PORT=

# Optional: disable the bundled health-check plugin (defaults to true).
ENABLE_HEALTH_CHECK=false
